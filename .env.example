# ---- Copy this file to ".env" and fill in the values ----

# ---- Azure authentication ----
# On the VM keep this true to use the user-assigned Managed Identity.
# Set to false locally to fall back to your `az login` identity.
USE_MANAGED_IDENTITY=true
# Managed Identity: Abyss-04
# NOTE: this must be the MI's CLIENT ID. The value below was given as "MI Id" -- if auth
# fails, it may actually be the OBJECT (principal) id: clear this line and set
# MANAGED_IDENTITY_OBJECT_ID instead.
MANAGED_IDENTITY_CLIENT_ID=9e11a244-d9b5-44a3-8234-07d2141b3f69
# Alternative to the client id (leave empty if the client id above works):
MANAGED_IDENTITY_OBJECT_ID=

# Tika server used for text extraction (PUT the file bytes, get text back)
TIKA_ENDPOINT=https://tr-tika.safesendwebsites.com/tika

# The downstream service that receives the OCR text as JSON
SERVICE_ENDPOINT=https://<your-service-host>/api/analyze
# Optional bearer token / API key for that service (leave empty if not needed)
SERVICE_API_KEY=

# Input / output files
INPUT_EXCEL=input.xlsx
OUTPUT_EXCEL=output.xlsx
# Leave SHEET_NAME empty to use the first sheet
SHEET_NAME=

# Column names in your Excel (change these to match your headers exactly)
COL_STORAGE=storage_name
COL_CONTAINER=container
COL_FULLPATH=full_path

# ---- Copy this file to ".env" and fill in the values ----

# ---- Azure authentication ----
# On the VM keep this true to use the user-assigned Managed Identity.
# Set to false locally to fall back to your `az login` identity.
USE_MANAGED_IDENTITY=true
# Managed Identity: Abyss-04
# NOTE: this must be the MI's CLIENT ID. The value below was given as "MI Id" -- if auth
# fails, it may actually be the OBJECT (principal) id: clear this line and set
# MANAGED_IDENTITY_OBJECT_ID instead.
MANAGED_IDENTITY_CLIENT_ID=9e11a244-d9b5-44a3-8234-07d2141b3f69
# Alternative to the client id (leave empty if the client id above works):
MANAGED_IDENTITY_OBJECT_ID=

# Tika server used for text extraction (PUT the file bytes, get text back)
TIKA_ENDPOINT=https://tr-tika.safesendwebsites.com/tika

# The downstream service that receives the extracted text as JSON
SERVICE_ENDPOINT=https://tr-orion-dev-guardpii.safesendwebsites.com/api/recognize
# SECRET: the x-functions-key for the recognize endpoint. DO NOT commit this.
SERVICE_FUNCTIONS_KEY=
# PII detection model to use (e.g. "llm").
DETECTION_MODEL=llm
# Only process these blob file types (comma-separated). Others (.msi, .zip, ...) are skipped.
ALLOWED_EXTENSIONS=png,pdf
# Also try blobs that have NO extension (often just a missing extension). Tika
# auto-detects the real type; if it can't parse the file, that row is skipped.
PROCESS_EXTENSIONLESS=true
# NOTE: x-operation-id is generated automatically (a fresh GUID per request) --
# reusing an operation id makes the service return HTTP 500.

# Input / output files. INPUT_FILE may be a .csv or .xlsx. A ready-to-use
# input_sample.csv (10 rows) ships with the repo.
INPUT_FILE=input_sample.csv
OUTPUT_EXCEL=output.xlsx
# Folder for the per-blob JSON responses (each file is named after its blob).
OUTPUT_DIR=response
# SHEET_NAME applies to Excel only (ignored for CSV); leave empty for the first sheet.
SHEET_NAME=

# Column names in your input file (must match the headers exactly).
# Storage, container and blob name are parsed from COL_FULLPATH; COL_STORAGE and
# COL_CONTAINER are optional fallbacks. Defaults below match input_sample.csv.
COL_STORAGE=Source
COL_CONTAINER=Container
COL_FULLPATH=FullPath
